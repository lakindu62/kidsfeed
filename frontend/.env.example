# Backend base URL. For local dev: http://localhost:3000 (with backend running),
# or leave unset to use the Vite proxy (same tab origin → proxy to port 3000).
VITE_API_URL=http://localhost:3000
VITE_CLERK_PUBLISHABLE_KEY=

# Meal distribution — these live in frontend/.env only (not backend/.env).
# School id = MongoDB ObjectId string for the school document.
VITE_MEAL_DISTRIBUTION_SCHOOL_ID=
VITE_MEAL_DISTRIBUTION_SCHOOL_NAME=
