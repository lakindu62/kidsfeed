{
  "name": "kidsfeed-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "School management backend server",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "concurrently \"nodemon src/app.js\" \"ngrok http 3000\"",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/unit-tests/**/*.test.js"],
    "transform": {}
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/express": "^2.0.7",
    "axios": "^1.13.5",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "multer": "^2.0.2",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.8.1",
    "vitest": "^4.1.4"
  }
}
