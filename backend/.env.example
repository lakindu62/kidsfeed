# Server
PORT=3000

# Environment
NODE_ENV=development

# Allowed frontend origins for CORS (comma-separated)
# FRONTEND_ORIGINS=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# Clerk Authentication API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Clerk Webhook Secret
# Note: Has to be exactly this key for @clerk/express to work automatically
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# CLERK_WEBHOOK_SIGNING_SECRET_RENDER=whsec_xxxxxxxxxxxxxxxxxxxx

# USDA Nutrition API
USDA_API_KEY=your_usda_api_key_here

# Open Food Facts Base URL
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org/api/v2/product
# OPEN_FOOD_FACTS_BASE_URL_DEV=https://world.openfoodfacts.net/api/v2/product
OPEN_FOOD_FACTS_USER_AGENT=KidsfeedApp/1.0 (local-dev@example.com)

# Resend - meal-distribution guardian no-show emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MEAL_DISTRIBUTION_EMAIL_FROM=onboarding@resend.dev

# QuickChart - chart image generation for PDFs and dashboard
QUICKCHART_BASE_URL=https://quickchart.io

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+10000000000